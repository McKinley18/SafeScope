{
  "name": "sentinel-safety-backend",
  "version": "1.0.0",
  "description": "Sentinel Safety Production Backend",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nodemon src/main.ts",
    "build": "tsc && npm run copy:engine",
    "start": "node dist/main.js",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate src/database/migrations/InitialMigration -d src/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "seed": "ts-node src/database/seed.ts",
    "standards:seed": "ts-node src/standards/seed/run-standards-seed.ts",
    "standards:test": "ts-node src/standards/tests/golden-standards-tests.ts",
    "standards:gemini": "node scripts/run-gemini-standards-batch.js",
    "copy:engine": "mkdir -p dist/engine && cp src/engine/*.js dist/engine/",
    "postbuild": "npm run copy:engine"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/typeorm": "^10.0.0",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.17",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.3.1",
    "@types/xml2js": "^0.4.14",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.3"
  }
}
